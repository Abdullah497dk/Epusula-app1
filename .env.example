# Supabase bağlantısı (Project Settings -> API)
# Bu değerleri .env dosyasına kopyalayıp doldurun. anon key herkese açıktır (güvenli).
VITE_SUPABASE_URL=https://<proje-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# Şifre sıfırlama e-postasındaki bağlantının döneceği herkese açık site adresi (ana site).
# Örn: https://epusula.com/  (WebView/APK için de bu adres kullanılır)
# Boş bırakılırsa mevcut tarayıcı adresi kullanılır.
VITE_APP_URL=https://<ana-site-adresi>/
